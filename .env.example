# Gmail SMTP sender. Generate the app password from Google Account security settings.
GMAIL_USER="your-gmail-address@gmail.com"
GMAIL_APP_PASSWORD="your-16-character-app-password"
MAIL_FROM="BNI AI 商務力 <your-gmail-address@gmail.com>"

# Organizer recipient. Can also be edited in /admin.
ORGANIZER_EMAIL="organizer@example.com"

# Admin password. Defaults to 123456 if omitted.
INVITATION_ADMIN_PASSWORD="123456"

# Public site URL used in deployment notes and future email links.
SITE_URL="https://your-vercel-project.vercel.app"

# Optional persistent storage for Vercel admin edits and registrations.
# Upstash Redis or Vercel KV both work with @upstash/redis.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# KV_REST_API_URL=""
# KV_REST_API_TOKEN=""
